@inherits StateContainerComponent<FeaturesViewModel>
@* @page "/admin/features"  *@
@using TradeUp.Client.ViewModels.Pages
@layout AdminMainLayout

@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthenticationStateProvider AuthenticationStateProvider


<h1 class="admin-page-title">Gestion des features</h1>
@if (ViewModel.Features == null)
{
    <p>Chargement...</p>
}
else
{
    <div class="btn-box">
        <div class="inner">
            <button onclick="@ViewModel.AddFeature" class="oi oi-plus add feature" />
        </div>
    </div>
    <div class="table">
        <div class="inner">
            <ul class="list-unstyled">
                <li class="table-header">
                    <p>Action</p><p>Id</p><p>Name</p><p>Short description</p><p>Required groups</p>
                </li>
                @if(ViewModel.Features.Count() == 0)
                {
                    <li class="table-item">
                        <p>Y a que dalle!</p>
                    </li>
                }

                @foreach (var feature in ViewModel.Features)
                {
                    <li class="table-item">
                        <p>
                            <button class="border-1" @onclick="() => ViewModel.UpdateFeature(feature.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear-fill" viewBox="0 0 16 16">
                                    <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z" />
                                </svg>
                            </button>

                        </p>
                        <p>@feature.Id</p>
                        <p>@feature.Name</p>
                        <p>@feature.ShortDescription</p>
                        @if (@feature.EnabledRoles.Length == 0)
                        {
                            <p>no role selected</p>
                        }
                        else
                        {
                            <p>
                                @foreach (var role in @feature.EnabledRoles)
                                {
                                    @switch (role)
                                    {
                                        case "SuperAdmin":
                                            <Tag Text="@role" Color="@Tag.TagColorName.red" />
                                            break;
                                        case "Essentiel":
                                            <Tag Text="@role" Color="@Tag.TagColorName.green" />
                                            break;
                                        case "Pro":
                                            <Tag Text="@role" Color="@Tag.TagColorName.aqua" />
                                            break;
                                        case "Premium":
                                            <Tag Text="@role" Color="@Tag.TagColorName.gold" />
                                            break;
                                        default:
                                            <Tag Text="@role" Color="@Tag.TagColorName.none" />
                                            break;
                                    }
                                }
                            </p>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>
}

@if(ViewModel.UpdatedFeature != null)
{
    <div id="popup-background">
        <div class="popup feature">
            <div class="inner">
                <form @onsubmit="@ViewModel.SaveFeature">
                    <InputText @bind-Value=ViewModel.UpdatedFeature.Name />
                    <InputText @bind-Value=ViewModel.UpdatedFeature.ShortDescription />
                    <button type="submit">Update</button>
                </form>
            </div>
        </div>
    </div>
}
